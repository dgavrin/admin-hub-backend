# Database Configuration
# Format: postgresql://username:password@host:port/database?params
DATABASE_URL=postgresql://pguser:pguserpassword@host:5432/dbname?connection_limit=10&pool_timeout=30

# JWT Configuration
# Generate strong secrets: openssl rand -base64 32
JWT_ACCESS_SECRET=your-access-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here
# JWT Token Expiration (in seconds)
JWT_ACCESS_EXPIRES_IN=3600000 # Access token expiration in seconds (60 minutes)
JWT_REFRESH_EXPIRES_IN=2592000000 # Refresh token expiration in seconds (30 days)

# Application Port (default: 3000)
PORT=3000

# Node Environment
environment=production

